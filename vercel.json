{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/markets/detail", "destination": "/api/markets?action=detail" },
    { "source": "/api/markets/pending-resolution", "destination": "/api/markets?action=pending-resolution" },
    { "source": "/api/groups/detail", "destination": "/api/groups/manage?action=detail" },
    { "source": "/api/groups/create", "destination": "/api/groups/manage?action=create" },
    { "source": "/api/groups/join", "destination": "/api/groups/manage?action=join" },
    { "source": "/api/groups/members", "destination": "/api/groups/manage?action=members" },
    { "source": "/api/groups/regenerate-invite", "destination": "/api/groups/manage?action=regenerate-invite" },
    { "source": "/api/users/sync", "destination": "/api/users?action=sync" },
    { "source": "/api/users/profile", "destination": "/api/users?action=profile" },
    { "source": "/api/users/bets", "destination": "/api/users?action=bets" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/distribute",
      "schedule": "0 6 * * *"
    }
  ]
}
